# ─── Required ────────────────────────────────────────────────────────────────
# Get your free Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Admin Dashboard ──────────────────────────────────────────────────────────
# Set a strong secret key to protect your admin dashboard
ADMIN_SECRET=change_this_to_a_strong_random_string

# ─── Optional ────────────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info

# Path where WhatsApp session is saved (so you don't re-scan QR every restart)
SESSION_PATH=./.wwebjs_auth

# Comma-separated list of allowed origins for CORS (leave * for open)
ALLOWED_ORIGINS=*
